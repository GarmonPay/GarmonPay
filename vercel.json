{
  "buildCommand": "rm -rf .next && npm run build",
  "crons": [
    {
      "path": "/api/cron/membership-renewal",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
