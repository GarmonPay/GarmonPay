# Supabase (from project settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (from Dashboard → Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=
# Webhook URL to add in Stripe Dashboard: https://garmonpay.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# Admin one-time setup (production only; set in Vercel env)
ADMIN_SETUP_SECRET=

# Optional: site URL for redirects and links (Vercel sets this automatically)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
# NEXT_PUBLIC_API_URL=https://garmonpay.com
# Arena fight server (Render): WebSocket URL for Socket.io (fight/spectate/tournaments)
# NEXT_PUBLIC_BOXING_WS_URL=wss://garmonpay-fight-server.onrender.com
# Optional: same URL for keep-alive/status (defaults from above)
# NEXT_PUBLIC_ARENA_WS_URL=wss://garmonpay-fight-server.onrender.com
# NEXT_PUBLIC_FIGHT_SERVER_URL=https://garmonpay-fight-server.onrender.com
# On the fight server (Render env): set CORS_ORIGIN=https://garmonpay.com

# Arena 3D fighter generation (Meshy)
# MESHY_API_KEY=
# Optional: Draco-compressed GLBs from gltf-transform / Meshy export
# NEXT_PUBLIC_MESHY_DRACO=1
# Optional: ring GLB under public/assets/meshy/rings/
# NEXT_PUBLIC_MESHY_RING_GLB=/assets/meshy/rings/arena-ring.glb

# Arena AI opponent (Claude)
# ANTHROPIC_API_KEY=

# Stripe publishable (client-side; from Dashboard → API keys)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= or STRIPE_PUBLISHABLE_KEY

# Auth security (production)
# Cloudflare Turnstile for signup anti-bot (https://dash.cloudflare.com/?to=/:account/turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# New-login email alerts (Resend: https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=GarmonPay <noreply@yourdomain.com>

# Supabase Auth: set recovery link expiry to 900 (15 min) in Dashboard → Auth → Email Templates.
# Enable "Confirm email" in Auth → Providers → Email for email verification.
